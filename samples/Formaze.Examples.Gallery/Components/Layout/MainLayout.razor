@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">Formaze Examples</MudText>
        <MudSpacer />
        <MudLink Href="https://formaze.dev" Target="_blank" Color="Color.Inherit">formaze.dev</MudLink>
    </MudAppBar>
    <MudDrawer Open="true" Elevation="1" Variant="DrawerVariant.Persistent">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All">Home</MudNavLink>
            <MudNavLink Href="contact-form">Contact form</MudNavLink>
            <MudNavLink Href="multi-field">Multi-field form</MudNavLink>
            <MudNavLink Href="admin-mode">Admin mode</MudNavLink>
            <MudNavLink Href="custom-renderer">Custom field renderer</MudNavLink>
            <MudNavLink Href="conditional-fields">Conditional fields</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
