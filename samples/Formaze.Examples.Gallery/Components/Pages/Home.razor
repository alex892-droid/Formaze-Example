@page "/"

<PageTitle>Formaze Examples</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Formaze Examples</MudText>
<MudText Class="mb-4">
    A small gallery of Formaze forms. Pick an example from the menu on the left.
    Each page is a self-contained snippet you can copy into your own app.
</MudText>

<MudList T="string" Dense="true">
    <MudListItem Href="contact-form" Icon="@Icons.Material.Filled.Mail" Text="Contact form — text, email and multiline fields" />
    <MudListItem Href="multi-field" Icon="@Icons.Material.Filled.Tune" Text="Multi-field form — enum, bool, date and numeric fields" />
    <MudListItem Href="field-types" Icon="@Icons.Material.Filled.Category" Text="All field types — every inferred editor in one model" />
    <MudListItem Href="submission" Icon="@Icons.Material.Filled.Send" Text="Submission handling — custom submit label and reading values" />
    <MudListItem Href="admin-mode" Icon="@Icons.Material.Filled.AdminPanelSettings" Text="Admin mode — configure the form live" />
    <MudListItem Href="custom-renderer" Icon="@Icons.Material.Filled.Brush" Text="Custom field renderer — override a field's rendering" />
    <MudListItem Href="conditional-fields" Icon="@Icons.Material.Filled.Rule" Text="Conditional fields — show a field based on another" />
</MudList>
